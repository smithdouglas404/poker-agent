{
  "manifest_version": 3,
  "name": "PokerNow Advisor",
  "version": "1.1",
  "description": "Real-time poker advice based on shuffle bias analysis",
  "permissions": ["storage", "scripting", "activeTab"],
  "host_permissions": [
    "https://www.pokernow.club/*",
    "https://pokernow.club/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "PokerNow Advisor"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.pokernow.club/*",
        "https://pokernow.club/*"
      ],
      "js": ["lib/model.js", "content.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["overlay.css", "lib/model.js"],
      "matches": ["https://www.pokernow.club/*", "https://pokernow.club/*"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
